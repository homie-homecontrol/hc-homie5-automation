{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rule",
  "description": "Rule configuration for hc-homie5-automation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "triggers", "actions"],
  "properties": {
    "name": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RuleTrigger"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RuleAction"
      }
    }
  },
  "definitions": {
    "RuleTrigger": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["trigger_value"],
          "properties": {
            "properties": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/PropertyRef"
              },
              "default": []
            },
            "queries": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/QueryDefinition"
              },
              "default": []
            },
            "trigger_value": {
              "$ref": "#/definitions/ValueConditionHomieValue"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["changed"],
          "properties": {
            "properties": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/PropertyRef"
              },
              "default": []
            },
            "queries": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/QueryDefinition"
              },
              "default": []
            },
            "changed": {
              "$ref": "#/definitions/ChangedTrigger"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["timer_id"],
          "properties": {
            "timer_id": {
              "type": "string"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schedule"],
          "properties": {
            "schedule": {
              "type": "string"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["topic", "trigger_value"],
          "properties": {
            "topic": {
              "type": "string"
            },
            "skip_retained": {
              "type": "boolean",
              "default": false
            },
            "skip_duplicated": {
              "type": "boolean",
              "default": false
            },
            "check_qos": {
              "type": "boolean",
              "default": false
            },
            "qos": {
              "$ref": "#/definitions/QoS"
            },
            "trigger_value": {
              "$ref": "#/definitions/ValueConditionString"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sun_phase", "min_after"],
          "properties": {
            "sun_phase": {
              "$ref": "#/definitions/SolarPhase"
            },
            "min_after": {
              "$ref": "#/definitions/Duration"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sun_phase", "min_before"],
          "properties": {
            "sun_phase": {
              "$ref": "#/definitions/SolarPhase"
            },
            "min_before": {
              "$ref": "#/definitions/Duration"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["sun_phase"],
          "properties": {
            "sun_phase": {
              "$ref": "#/definitions/SolarPhase"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["set_value"],
          "properties": {
            "properties": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/PropertyRef"
              },
              "default": []
            },
            "queries": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/QueryDefinition"
              },
              "default": []
            },
            "set_value": {
              "$ref": "#/definitions/ValueConditionString"
            },
            "while": {
              "$ref": "#/definitions/WhileConditionSet"
            }
          }
        }
      ]
    },
    "RuleAction": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "target", "value"],
          "properties": {
            "type": {
              "const": "set"
            },
            "target": {
              "$ref": "#/definitions/PropertyRef"
            },
            "value": {
              "$ref": "#/definitions/HomieValue"
            },
            "timer": {
              "$ref": "#/definitions/TimerDef"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "target", "mapping"],
          "properties": {
            "type": {
              "const": "map_set"
            },
            "target": {
              "$ref": "#/definitions/PropertyRef"
            },
            "mapping": {
              "$ref": "#/definitions/ValueMappingListMapSetFromToHomieValue"
            },
            "timer": {
              "$ref": "#/definitions/TimerDef"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "target"],
          "properties": {
            "type": {
              "const": "toggle"
            },
            "target": {
              "$ref": "#/definitions/PropertyRef"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "script"],
          "properties": {
            "type": {
              "const": "run"
            },
            "script": {
              "type": "string"
            },
            "timer": {
              "$ref": "#/definitions/TimerDef"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "timer"],
          "properties": {
            "type": {
              "const": "timer"
            },
            "timer": {
              "$ref": "#/definitions/TimerDef"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "timer_id"],
          "properties": {
            "type": {
              "const": "cancel_timer"
            },
            "timer_id": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "topic", "value"],
          "properties": {
            "type": {
              "const": "mqtt"
            },
            "topic": {
              "type": "string"
            },
            "value": {
              "type": "string"
            },
            "qos": {
              "$ref": "#/definitions/QoS"
            },
            "retain": {
              "type": "boolean",
              "default": false
            }
          }
        }
      ]
    },
    "TimerDef": {
      "type": "object",
      "required": ["id", "duration"],
      "properties": {
        "id": {
          "type": "string"
        },
        "duration": {
          "$ref": "#/definitions/Duration"
        },
        "repeat": {
          "$ref": "#/definitions/Duration"
        },
        "triggerbound": {
          "type": "boolean",
          "default": false
        },
        "cancelcondition": {
          "$ref": "#/definitions/ValueConditionHomieValue"
        }
      }
    },
    "ChangedTrigger": {
      "type": "object",
      "properties": {
        "from": {
          "$ref": "#/definitions/ValueConditionHomieValue"
        },
        "to": {
          "$ref": "#/definitions/ValueConditionHomieValue"
        }
      }
    },
    "WhileConditionSet": {
      "oneOf": [
        {
          "$ref": "#/definitions/WhileCondition"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/WhileCondition"
          }
        }
      ]
    },
    "WhileCondition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["property", "condition"],
          "properties": {
            "property": {
              "$ref": "#/definitions/PropertyRef"
            },
            "condition": {
              "$ref": "#/definitions/ValueConditionHomieValue"
            }
          }
        },
        {
          "$ref": "#/definitions/TimeWhileCondition"
        }
      ]
    },
    "TimeWhileCondition": {
      "oneOf": [
        {
          "type": "object",
          "required": ["after", "before", "weekdays"],
          "properties": {
            "after": {
              "$ref": "#/definitions/TimeOfDay"
            },
            "before": {
              "$ref": "#/definitions/TimeOfDay"
            },
            "weekdays": {
              "$ref": "#/definitions/Weekdays"
            }
          }
        },
        {
          "type": "object",
          "required": ["before"],
          "properties": {
            "before": {
              "$ref": "#/definitions/TimeOfDay"
            },
            "weekdays": {
              "$ref": "#/definitions/Weekdays"
            }
          }
        },
        {
          "type": "object",
          "required": ["after"],
          "properties": {
            "after": {
              "$ref": "#/definitions/TimeOfDay"
            },
            "weekdays": {
              "$ref": "#/definitions/Weekdays"
            }
          }
        },
        {
          "type": "object",
          "required": ["weekdays"],
          "properties": {
            "weekdays": {
              "$ref": "#/definitions/Weekdays"
            }
          }
        }
      ]
    },
    "Weekdays": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Weekday"
      }
    },
    "Weekday": {
      "type": "string",
      "enum": ["sun", "mon", "tue", "wed", "thu", "fri", "sat"]
    },
    "Duration": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|d)$"
    },
    "TimeOfDay": {
      "type": "string",
      "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$"
    },
    "QoS": {
      "oneOf": [
        {
          "type": "integer",
          "enum": [0, 1, 2]
        },
        {
          "type": "string",
          "enum": ["AtMostOnce", "AtLeastOnce", "ExactlyOnce"]
        }
      ]
    },
    "SolarPhase": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "sunrise",
            "sunset",
            "sunriseEnd",
            "sunsetStart",
            "dawn",
            "dusk",
            "nauticalDawn",
            "nauticalDusk",
            "nightEnd",
            "night",
            "goldenHourEnd",
            "goldenHour"
          ]
        },
        {
          "type": "object",
          "required": ["Custom"],
          "properties": {
            "Custom": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": [
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "PropertyRef": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^([^/]+/)?[^/]+/[^/]+/[^/]+$"
        },
        {
          "type": "object",
          "required": ["device_id", "node_id", "prop_id"],
          "properties": {
            "homie_domain": {
              "type": "string"
            },
            "device_id": {
              "type": "string"
            },
            "node_id": {
              "type": "string"
            },
            "prop_id": {
              "type": "string"
            }
          }
        }
      ]
    },
    "QueryDefinition": {
      "type": "object"
    },
    "HomieValue": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "object"
        },
        {
          "type": "array"
        },
        {
          "type": "null"
        }
      ]
    },
    "ValueConditionHomieValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/HomieValue"
        },
        {
          "type": "object"
        }
      ]
    },
    "ValueConditionString": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object"
        }
      ]
    },
    "MapSetFrom": {
      "oneOf": [
        {
          "type": "object",
          "required": ["HomieValue"],
          "properties": {
            "HomieValue": {
              "$ref": "#/definitions/HomieValue"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["String"],
          "properties": {
            "String": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["SolarPhase"],
          "properties": {
            "SolarPhase": {
              "$ref": "#/definitions/SolarPhase"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "ValueMappingListMapSetFromToHomieValue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["to"],
        "properties": {
          "from": {
            "$ref": "#/definitions/MapSetFrom"
          },
          "to": {
            "$ref": "#/definitions/HomieValue"
          }
        }
      }
    }
  }
}
