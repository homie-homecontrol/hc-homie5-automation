{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VirtualDeviceSpec",
  "description": "Virtual device configuration for hc-homie5-automation.",
  "$ref": "#/definitions/VirtualDeviceSpec",
  "definitions": {
    "VirtualDeviceSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "nodes"],
      "properties": {
        "id": {
          "$ref": "#/definitions/HomieID"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "integer"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HomieID"
          },
          "default": []
        },
        "parent": {
          "$ref": "#/definitions/HomieID"
        },
        "extensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/VirtualNodeSpec"
          }
        }
      }
    },
    "VirtualNodeSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "$ref": "#/definitions/HomieID"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "from_smarthome": {
          "$ref": "#/definitions/SmarthomeSpec"
        },
        "pass_through": {
          "type": "boolean"
        },
        "property_opts": {
          "$ref": "#/definitions/VirtualPropertyOptions"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/VirtualPropertySpec"
          },
          "default": []
        }
      }
    },
    "VirtualPropertySpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "$ref": "#/definitions/HomieID"
        },
        "name": {
          "type": "string"
        },
        "datatype": {
          "$ref": "#/definitions/HomieDataType"
        },
        "format": {
          "type": "string"
        },
        "settable": {
          "type": "boolean"
        },
        "retained": {
          "type": "boolean"
        },
        "unit": {
          "type": "string"
        },
        "pass_through": {
          "type": "boolean"
        },
        "property_opts": {
          "$ref": "#/definitions/VirtualPropertyOptions"
        },
        "compound_spec": {
          "$ref": "#/definitions/CompoundSpec"
        }
      }
    },
    "VirtualPropertyOptions": {
      "type": "object",
      "properties": {
        "read_from_mqtt": {
          "type": "boolean",
          "default": false
        },
        "read_timeout": {
          "$ref": "#/definitions/Duration"
        }
      }
    },
    "CompoundSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["members"],
      "properties": {
        "members": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MemberSpec"
          }
        },
        "mapping": {
          "$ref": "#/definitions/ValueMappingIOHomieValue"
        },
        "aggregate_function": {
          "$ref": "#/definitions/AggregateFunctionType",
          "default": "equal"
        },
        "aggregation_debounce": {
          "$ref": "#/definitions/Duration"
        }
      }
    },
    "MemberSpec": {
      "oneOf": [
        {
          "$ref": "#/definitions/PropertyRef"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["property", "mapping"],
          "properties": {
            "property": {
              "$ref": "#/definitions/PropertyRef"
            },
            "mapping": {
              "$ref": "#/definitions/ValueMappingIOHomieValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["query"],
          "properties": {
            "query": {
              "$ref": "#/definitions/QueryDefinition"
            },
            "mapping": {
              "$ref": "#/definitions/ValueMappingIOHomieValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["mqtt_input"],
          "properties": {
            "mqtt_input": {
              "$ref": "#/definitions/MqttWrapperChannelStringToHomieValue"
            },
            "mqtt_output": {
              "$ref": "#/definitions/MqttWrapperChannelHomieValueToString"
            }
          }
        }
      ]
    },
    "MqttWrapperChannelStringToHomieValue": {
      "type": "object",
      "required": ["topic", "mapping"],
      "properties": {
        "topic": {
          "type": "string"
        },
        "mapping": {
          "$ref": "#/definitions/ValueMappingListStringToHomieValue"
        },
        "retained": {
          "type": "boolean",
          "default": false
        },
        "qos": {
          "$ref": "#/definitions/QoS"
        }
      }
    },
    "MqttWrapperChannelHomieValueToString": {
      "type": "object",
      "required": ["topic", "mapping"],
      "properties": {
        "topic": {
          "type": "string"
        },
        "mapping": {
          "$ref": "#/definitions/ValueMappingListHomieValueToString"
        },
        "retained": {
          "type": "boolean",
          "default": false
        },
        "qos": {
          "$ref": "#/definitions/QoS"
        }
      }
    },
    "ValueMappingIOHomieValue": {
      "type": "object",
      "properties": {
        "input": {
          "$ref": "#/definitions/ValueMappingListHomieValueToHomieValue"
        },
        "output": {
          "$ref": "#/definitions/ValueMappingListHomieValueToHomieValue"
        }
      }
    },
    "ValueMappingListStringToHomieValue": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ValueMappingItemStringToHomieValue"
      }
    },
    "ValueMappingListHomieValueToString": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ValueMappingItemHomieValueToString"
      }
    },
    "ValueMappingListHomieValueToHomieValue": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ValueMappingItemHomieValueToHomieValue"
      }
    },
    "ValueMappingItemStringToHomieValue": {
      "type": "object",
      "required": ["to"],
      "properties": {
        "from": {
          "$ref": "#/definitions/ValueConditionString"
        },
        "to": {
          "$ref": "#/definitions/HomieValue"
        }
      }
    },
    "ValueMappingItemHomieValueToString": {
      "type": "object",
      "required": ["to"],
      "properties": {
        "from": {
          "$ref": "#/definitions/ValueConditionHomieValue"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "ValueMappingItemHomieValueToHomieValue": {
      "type": "object",
      "required": ["to"],
      "properties": {
        "from": {
          "$ref": "#/definitions/ValueConditionHomieValue"
        },
        "to": {
          "$ref": "#/definitions/HomieValue"
        }
      }
    },
    "ValueConditionString": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object"
        }
      ]
    },
    "ValueConditionHomieValue": {
      "anyOf": [
        {
          "$ref": "#/definitions/HomieValue"
        },
        {
          "type": "object"
        }
      ]
    },
    "PropertyRef": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^([^/]+/)?[^/]+/[^/]+/[^/]+$"
        },
        {
          "type": "object",
          "required": ["device_id", "node_id", "prop_id"],
          "properties": {
            "homie_domain": {
              "type": "string"
            },
            "device_id": {
              "type": "string"
            },
            "node_id": {
              "type": "string"
            },
            "prop_id": {
              "type": "string"
            }
          }
        }
      ]
    },
    "QueryDefinition": {
      "type": "object"
    },
    "HomieValue": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "object"
        },
        {
          "type": "array"
        },
        {
          "type": "null"
        }
      ]
    },
    "HomieDataType": {
      "type": "string",
      "enum": ["boolean", "integer", "float", "string", "enum", "color", "datetime", "duration", "json"]
    },
    "AggregateFunctionType": {
      "type": "string",
      "enum": ["equal", "or", "and", "nor", "nand", "avg", "avgceil", "max", "min"]
    },
    "QoS": {
      "oneOf": [
        {
          "type": "integer",
          "enum": [0, 1, 2]
        },
        {
          "type": "string",
          "enum": ["AtMostOnce", "AtLeastOnce", "ExactlyOnce"]
        }
      ]
    },
    "Duration": {
      "type": "string",
      "pattern": "^[0-9]+(ms|s|m|d)$"
    },
    "HomieID": {
      "type": "string",
      "pattern": "^(?!-)[a-z0-9\\-]+(?<!-)$"
    },
    "SmarthomeSpec": {
      "oneOf": [
        { "$ref": "#/definitions/SmarthomeSpecAirQuality" },
        { "$ref": "#/definitions/SmarthomeSpecAlarm" },
        { "$ref": "#/definitions/SmarthomeSpecBattery" },
        { "$ref": "#/definitions/SmarthomeSpecButton" },
        { "$ref": "#/definitions/SmarthomeSpecCamera" },
        { "$ref": "#/definitions/SmarthomeSpecClimate" },
        { "$ref": "#/definitions/SmarthomeSpecColor" },
        { "$ref": "#/definitions/SmarthomeSpecDaylight" },
        { "$ref": "#/definitions/SmarthomeSpecGarageDoor" },
        { "$ref": "#/definitions/SmarthomeSpecLevel" },
        { "$ref": "#/definitions/SmarthomeSpecLink" },
        { "$ref": "#/definitions/SmarthomeSpecLock" },
        { "$ref": "#/definitions/SmarthomeSpecMediaInfo" },
        { "$ref": "#/definitions/SmarthomeSpecMediaplayer" },
        { "$ref": "#/definitions/SmarthomeSpecPowermeter" },
        { "$ref": "#/definitions/SmarthomeSpecScene" },
        { "$ref": "#/definitions/SmarthomeSpecShutter" },
        { "$ref": "#/definitions/SmarthomeSpecSwitch" },
        { "$ref": "#/definitions/SmarthomeSpecThermostat" },
        { "$ref": "#/definitions/SmarthomeSpecTimer" },
        { "$ref": "#/definitions/SmarthomeSpecValve" },
        { "$ref": "#/definitions/SmarthomeSpecVibration" },
        { "$ref": "#/definitions/SmarthomeSpecVolume" },
        { "$ref": "#/definitions/SmarthomeSpecCo" },
        { "$ref": "#/definitions/SmarthomeSpecContact" },
        { "$ref": "#/definitions/SmarthomeSpecIlluminance" },
        { "$ref": "#/definitions/SmarthomeSpecMotion" },
        { "$ref": "#/definitions/SmarthomeSpecOrientation" },
        { "$ref": "#/definitions/SmarthomeSpecSmoke" },
        { "$ref": "#/definitions/SmarthomeSpecText" },
        { "$ref": "#/definitions/SmarthomeSpecTilt" },
        { "$ref": "#/definitions/SmarthomeSpecWaterSensor" }
      ]
    },
    "SmarthomeSpecAirQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "air-quality" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecAlarm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "alarm" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecBattery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "battery" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecButton": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "button" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecCamera": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "camera" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecClimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "climate" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecColor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "color" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecDaylight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "daylight" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecGarageDoor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "garage-door" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecLevel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "level" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "link" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "lock" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecMediaInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "media-info" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecMediaplayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "mediaplayer" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecPowermeter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "powermeter" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecScene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "scene" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecShutter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "shutter" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecSwitch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "switch" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecThermostat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "thermostat" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecTimer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "timer" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecValve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "valve" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecVibration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "vibration" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "volume" },
        "config": { "type": "object" }
      }
    },
    "SmarthomeSpecCo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "co" }
      }
    },
    "SmarthomeSpecContact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "contact" }
      }
    },
    "SmarthomeSpecIlluminance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "illuminance" }
      }
    },
    "SmarthomeSpecMotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "motion" }
      }
    },
    "SmarthomeSpecOrientation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "orientation" }
      }
    },
    "SmarthomeSpecSmoke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "smoke" }
      }
    },
    "SmarthomeSpecText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "text" }
      }
    },
    "SmarthomeSpecTilt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "tilt" }
      }
    },
    "SmarthomeSpecWaterSensor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "watersensor" }
      }
    }
  }
}
